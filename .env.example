# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OPENAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- GOOGLE GEMINI (FALLBACK IA) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# --- GOOGLE AUTH ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GITHUB AUTH ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- STRIPE ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- SEGURANÇA ---
ENCRYPTION_SECRET_KEY=
CSRF_SECRET=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_MAX_AGE_HOURS=24
MAX_SESSIONS_PER_USER=5
BCRYPT_ROUNDS=12

# --- 2FA ---
TWO_FACTOR_APP_NAME=NeuraFin Hub
TWO_FACTOR_ISSUER=neurafin.app

# --- OPEN FINANCE ---
OPEN_FINANCE_MODE=mock
# OPEN_FINANCE_CLIENT_ID=
# OPEN_FINANCE_CLIENT_SECRET=
# OPEN_FINANCE_BASE_URL=https://api.openfinance.com.br

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NeuraFin Hub
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development

# --- CRON SECRET (Vercel) ---
CRON_SECRET=

# --- MOBILE ---
NEXT_PUBLIC_PLATFORM=web
NEXT_PUBLIC_ANDROID_PACKAGE=com.neurafin.hub
